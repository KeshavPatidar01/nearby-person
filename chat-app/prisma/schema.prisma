// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// 👇 YE BLOCK MISSING THA
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODELS ---
model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
imageUrl  String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  // Relations
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  
  // Implicit Many-to-Many relation for conversations
  conversations    Conversation[]
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  
  // Relations
  users     User[]    
  messages  Message[] 
}
model Message {
  id             String       @id @default(uuid())
  content        String
  createdAt      DateTime     @default(now())
reaction       String?
  // Sender (Ye zaroori hai)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [clerkId])
  
  // 👇 CHANGE HERE: Dono ke aage '?' lagao (Optional banao)
  receiverId     String?      
  receiver       User?        @relation("ReceivedMessages", fields: [receiverId], references: [clerkId])
  isRead         Boolean  @default(false)

  // Conversation (Ye zaroori hai)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}